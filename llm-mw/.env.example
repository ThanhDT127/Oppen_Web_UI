# Middleware -> LiteLLM
LITELLM_BASE=http://127.0.0.1:4000/v1
LITELLM_KEY=<LITELLM_MASTER_KEY>

# Provider keys used by LiteLLM config (litellm/litellm_config.yaml)
OPENAI_API_KEY=<OPENAI_API_KEY>
GEMINI_API_KEY=<GEMINI_API_KEY>

# Middleware admin endpoints
ADMIN_KEY=<MW_ADMIN_KEY>

# Middleware Security Keys (REQUIRED - Generate secure random strings)
JWT_SECRET=<JWT_SECRET_MIN_32_CHARS>
MW_SECRET=<MW_SECRET_MIN_32_CHARS>

# OpenWebUI data dir (OpenWebUI reads this env var)
# Nếu muốn OpenWebUI lưu DB ngay trong project:
DATA_DIR=D:/ktlt/Works/oppenwebui2/openwebui_data
