<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LLM Middleware Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            padding: 20px;
        }
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .header h1 {
            font-size: 32px;
            margin-bottom: 10px;
        }
        .header p {
            opacity: 0.9;
            font-size: 14px;
        }
        .metrics {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .metric-card {
            background: #1e293b;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid #667eea;
            transition: transform 0.2s;
        }
        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.4);
        }
        .metric-label {
            font-size: 12px;
            text-transform: uppercase;
            opacity: 0.7;
            margin-bottom: 8px;
        }
        .metric-value {
            font-size: 28px;
            font-weight: 700;
            color: #60a5fa;
        }
        .section {
            background: #1e293b;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .section-title {
            font-size: 18px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #334155;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            text-align: left;
            padding: 10px;
            background: #334155;
            font-weight: 600;
            font-size: 14px;
        }
        td {
            padding: 10px;
            border-bottom: 1px solid #334155;
            font-size: 14px;
        }
        tr:hover {
            background: #2d3748;
        }
        .status-ok { color: #10b981; }
        .status-error { color: #ef4444; }
        .status-pending { color: #f59e0b; }
        .status-reconciled { color: #3b82f6; }
        #events {
            max-height: 400px;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 12px;
        }
        .event-line {
            padding: 8px;
            border-bottom: 1px solid #334155;
            display: flex;
            gap: 10px;
        }
        .event-time {
            color: #64748b;
            min-width: 80px;
        }
        .event-status {
            min-width: 80px;
            font-weight: 600;
        }
        .event-detail {
            flex: 1;
            opacity: 0.8;
        }
        .auth-prompt {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .auth-box {
            background: #1e293b;
            padding: 40px;
            border-radius: 12px;
            max-width: 400px;
            width: 100%;
        }
        .auth-box h2 {
            margin-bottom: 20px;
        }
        .auth-box input {
            width: 100%;
            padding: 12px;
            border: 1px solid #334155;
            background: #0f172a;
            color: #e2e8f0;
            border-radius: 6px;
            font-size: 14px;
            margin-bottom: 15px;
        }
        .auth-box button {
            width: 100%;
            padding: 12px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            font-weight: 600;
        }
        .auth-box button:hover {
            background: #5568d3;
        }
        .error-msg {
            color: #ef4444;
            font-size: 12px;
            margin-top: -10px;
            margin-bottom: 10px;
        }
        .hidden { display: none; }
        .loading {
            text-align: center;
            padding: 40px;
            opacity: 0.7;
        }
    </style>
</head>
<body>
    <div id="authPrompt" class="auth-prompt">
        <div class="auth-box">
            <h2>🔐 Admin Authentication</h2>
            <p style="opacity: 0.8; margin-bottom: 20px; font-size: 14px;">
                Enter your admin key to access the dashboard
            </p>
            <input type="password" id="adminKeyInput" placeholder="Admin Key" autocomplete="off">
            <div id="authError" class="error-msg hidden"></div>
            <button onclick="authenticate()">Access Dashboard</button>
        </div>
    </div>

    <div id="dashboard" class="hidden">
        <div class="header">
            <h1>📊 LLM Middleware Dashboard</h1>
            <p>Realtime monitoring and usage analytics</p>
        </div>

        <div class="metrics">
            <div class="metric-card">
                <div class="metric-label">Total Requests</div>
                <div class="metric-value" id="metricTotal">-</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Pending</div>
                <div class="metric-value" id="metricPending">-</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Error Rate</div>
                <div class="metric-value" id="metricErrorRate">-</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">P95 Latency</div>
                <div class="metric-value" id="metricLatency">-</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Total Tokens</div>
                <div class="metric-value" id="metricTokens">-</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Total Cost</div>
                <div class="metric-value" id="metricCost">-</div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">🏆 Top Users by Cost</div>
            <table>
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Cost (USD)</th>
                    </tr>
                </thead>
                <tbody id="topUsersTable">
                    <tr><td colspan="2" class="loading">Loading...</td></tr>
                </tbody>
            </table>
        </div>

        <div class="section">
            <div class="section-title">🤖 Top Models by Cost</div>
            <table>
                <thead>
                    <tr>
                        <th>Model</th>
                        <th>Cost (USD)</th>
                    </tr>
                </thead>
                <tbody id="topModelsTable">
                    <tr><td colspan="2" class="loading">Loading...</td></tr>
                </tbody>
            </table>
        </div>

        <div class="section">
            <div class="section-title">📡 Recent Events (Last 50)</div>
            <div id="events">
                <div class="loading">Connecting to event stream...</div>
            </div>
        </div>
    </div>

    <script>
        let eventSource = null;

        function authenticate() {
            const input = document.getElementById('adminKeyInput');
            const key = input.value.trim();
            
            if (!key) {
                showError('Please enter admin key');
                return;
            }

            // Call login endpoint to set session cookie
            fetch('/v1/_mw/dashboard/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                credentials: 'include',  // Important: send/receive cookies
                body: JSON.stringify({
                    admin_key: key
                })
            })
            .then(res => {
                if (res.status === 403) {
                    throw new Error('Invalid admin key');
                }
                if (!res.ok) {
                    throw new Error('Login failed');
                }
                return res.json();
            })
            .then(data => {
                // Success - cookie is set, hide auth prompt and show dashboard
                document.getElementById('authPrompt').classList.add('hidden');
                document.getElementById('dashboard').classList.remove('hidden');
                
                // Start dashboard
                startDashboard();
            })
            .catch(err => {
                showError(err.message || 'Authentication failed');
            });
        }

        function showError(msg) {
            const errorDiv = document.getElementById('authError');
            errorDiv.textContent = msg;
            errorDiv.classList.remove('hidden');
        }

        function startDashboard() {
            // Initial data load
            updateSummary();
            
            // Poll summary every 5 seconds
            setInterval(updateSummary, 5000);
            
            // Connect to SSE stream
            connectEventStream();
        }

        function updateSummary() {
            fetch('http://localhost:5000/v1/_mw/summary?minutes=30', {
                credentials: 'include'  // Send cookie
            })
            .then(res => {
                if (res.status === 403) {
                    // Session expired, redirect to login
                    window.location.reload();
                    return null;
                }
                return res.json();
            })
            .then(data => {
                if (!data) return;
                
                // Update metrics
                document.getElementById('metricTotal').textContent = data.requests_total || 0;
                document.getElementById('metricPending').textContent = data.pending_count || 0;
                document.getElementById('metricErrorRate').textContent = 
                    (data.error_rate_percent || 0).toFixed(1) + '%';
                document.getElementById('metricLatency').textContent = 
                    data.p95_latency_ms ? data.p95_latency_ms.toFixed(0) + 'ms' : '-';
                document.getElementById('metricTokens').textContent = 
                    (data.tokens_total || 0).toLocaleString();
                document.getElementById('metricCost').textContent = 
                    '$' + (data.cost_total_usd || 0).toFixed(4);
                
                // Update top users
                const usersTable = document.getElementById('topUsersTable');
                if (data.top_users && data.top_users.length > 0) {
                    usersTable.innerHTML = data.top_users.map(u => 
                        `<tr><td>${u.user_id}</td><td>$${u.cost_usd.toFixed(6)}</td></tr>`
                    ).join('');
                } else {
                    usersTable.innerHTML = '<tr><td colspan="2">No data</td></tr>';
                }
                
                // Update top models
                const modelsTable = document.getElementById('topModelsTable');
                if (data.top_models && data.top_models.length > 0) {
                    modelsTable.innerHTML = data.top_models.map(m => 
                        `<tr><td>${m.model}</td><td>$${m.cost_usd.toFixed(6)}</td></tr>`
                    ).join('');
                } else {
                    modelsTable.innerHTML = '<tr><td colspan="2">No data</td></tr>';
                }
            })
            .catch(err => {
                console.error('Failed to update summary:', err);
            });
        }

        function connectEventStream() {
            const eventsDiv = document.getElementById('events');
            eventsDiv.innerHTML = '<div class="loading">Connecting...</div>';
            
            // EventSource automatically sends cookies
            eventSource = new EventSource('http://localhost:5000/v1/_mw/stream', {
                withCredentials: true
            });
            
            eventSource.addEventListener('audit', (e) => {
                const data = JSON.parse(e.data);
                addEvent(data);
            });
            
            eventSource.addEventListener('error', (e) => {
                console.error('EventSource error:', e);
                
                if (eventSource.readyState === EventSource.CLOSED) {
                    eventsDiv.innerHTML = '<div class="error-msg">Stream disconnected. Reconnecting...</div>';
                    
                    // Reconnect after 5 seconds
                    setTimeout(() => {
                        if (eventSource) {
                            eventSource.close();
                        }
                        connectEventStream();
                    }, 5000);
                }
            });
            
            eventSource.onopen = () => {
                eventsDiv.innerHTML = '';
            };
        }

        function addEvent(data) {
            const eventsDiv = document.getElementById('events');
            
            // Create event line
            const line = document.createElement('div');
            line.className = 'event-line';
            
            // Format timestamp
            const time = new Date(data.ts).toLocaleTimeString();
            
            // Status class
            const statusClass = `status-${data.status}`;
            
            line.innerHTML = `
                <span class="event-time">${time}</span>
                <span class="event-status ${statusClass}">${data.status.toUpperCase()}</span>
                <span class="event-detail">
                    ${data.user_id} | ${data.model} | 
                    ${data.tokens_total || 0} tokens | 
                    $${(data.cost_usd || 0).toFixed(6)}
                </span>
            `;
            
            // Add to top
            eventsDiv.insertBefore(line, eventsDiv.firstChild);
            
            // Keep only last 50 events
            while (eventsDiv.children.length > 50) {
                eventsDiv.removeChild(eventsDiv.lastChild);
            }
        }

        // Allow Enter key to authenticate
        document.getElementById('adminKeyInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                authenticate();
            }
        });
        
        // Check if already logged in on page load
        window.addEventListener('load', () => {
            // Try to load summary - if success, user is logged in
            fetch('http://localhost:5000/v1/_mw/summary?minutes=5', {
                credentials: 'include'
            })
            .then(res => {
                if (res.ok) {
                    // Already logged in, skip auth prompt
                    document.getElementById('authPrompt').classList.add('hidden');
                    document.getElementById('dashboard').classList.remove('hidden');
                    startDashboard();
                }
                // If 403, stay on login screen
            })
            .catch(() => {
                // Network error or 403, stay on login screen
            });
        });
    </script>
</body>
</html>
