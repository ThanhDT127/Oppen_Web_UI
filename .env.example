# LiteLLM Configuration
LITELLM_BASE=http://127.0.0.1:4000/v1
LITELLM_KEY=your-litellm-admin-key-here

# Middleware Admin Key
ADMIN_KEY=your-admin-master-key-here

# Middleware Security Keys (REQUIRED - Generate secure random strings)
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
MW_SECRET=your-middleware-secret-change-in-production-min-32-chars

# OpenWebUI Database Directory (MUST be absolute path)
DATA_DIR=D:\Works\Oppen_Web_UI_fresh\openwebui_data
WEBUI_SECRET_KEY=your-webui-secret-key-here

# Provider API Keys (used by LiteLLM config: litellm/litellm_config.yaml)
# NOTE: NEVER commit real API keys to version control
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
