model_list:
  # ============================================================
  # OPENAI CHAT MODELS (3)
  # ============================================================

  # GPT-5.4 (Flagship — Mar 2026, 1M context)
  - model_name: chat-gpt-5.4
    litellm_params:
      model: openai/gpt-5.4
      api_key: os.environ/OPENAI_API_KEY

  # GPT-5.2 (Dec 2025, 400K context)
  - model_name: chat-gpt-5.2
    litellm_params:
      model: openai/gpt-5.2
      api_key: os.environ/OPENAI_API_KEY

  # GPT-5 (Aug 2025, multimodal)
  - model_name: chat-gpt-5
    litellm_params:
      model: openai/gpt-5
      api_key: os.environ/OPENAI_API_KEY

  # ============================================================
  # GOOGLE GEMINI CHAT MODELS (3)
  # ============================================================

  # Gemini 3.1 Pro (Flagship — Feb 2026, 1M context)
  - model_name: chat-gemini-3.1-pro
    litellm_params:
      model: gemini/gemini-3.1-pro-preview
      api_key: os.environ/GEMINI_API_KEY

  # Gemini 3.1 Flash-Lite (Budget — Mar 2026, 1M context)
  - model_name: chat-gemini-3.1-flash
    litellm_params:
      model: gemini/gemini-3.1-flash-lite-preview
      api_key: os.environ/GEMINI_API_KEY

  # Gemini 2.5 Flash (Stable — mid-tier)
  - model_name: chat-gemini-2.5-flash
    litellm_params:
      model: gemini/gemini-2.5-flash
      api_key: os.environ/GEMINI_API_KEY

  # ============================================================
  # XAI GROK CHAT MODELS (3)
  # ============================================================

  # Grok 4.20 Reasoning (Flagship — Feb 2026, 2M context, multi-agent)
  - model_name: chat-grok-4.20
    litellm_params:
      model: xai/grok-4.20-reasoning
      api_key: os.environ/XAI_API_KEY

  # Grok 4.1 Fast Reasoning (2M context, cheap, reasoning)
  - model_name: chat-grok-4.1-fast
    litellm_params:
      model: xai/grok-4-1-fast-reasoning
      api_key: os.environ/XAI_API_KEY

  # Grok 4.1 Fast Non-Reasoning (2M context, fastest, no reasoning)
  - model_name: chat-grok-4.1-fast-lite
    litellm_params:
      model: xai/grok-4-1-fast-non-reasoning
      api_key: os.environ/XAI_API_KEY

  # ============================================================
  # ANTHROPIC CLAUDE CHAT MODELS (3)
  # ============================================================

  # Claude Opus 4.6 (Most capable — deep reasoning, 200K)
  - model_name: chat-claude-opus-4.6
    litellm_params:
      model: anthropic/claude-opus-4-6
      api_key: os.environ/ANTHROPIC_API_KEY

  # Claude Sonnet 4.6 (Balanced — great for code, 200K)
  - model_name: chat-claude-sonnet-4.6
    litellm_params:
      model: anthropic/claude-sonnet-4-6
      api_key: os.environ/ANTHROPIC_API_KEY

  # Claude Haiku 4.5 (Fast + cheap, 200K)
  - model_name: chat-claude-haiku-4.5
    litellm_params:
      model: anthropic/claude-haiku-4-5
      api_key: os.environ/ANTHROPIC_API_KEY

  # ============================================================
  # IMAGE GENERATION MODELS
  # ============================================================

  # OpenAI GPT Image 1.5 (Latest, best quality)
  - model_name: img-gpt-1.5
    litellm_params:
      model: openai/gpt-image-1.5
      api_key: os.environ/OPENAI_API_KEY

  # OpenAI GPT Image 1 (High quality)
  - model_name: img-gpt-1
    litellm_params:
      model: openai/gpt-image-1
      api_key: os.environ/OPENAI_API_KEY

  # Gemini 3.1 Flash Image (Fast, 1024px)
  - model_name: img-gemini-3.1-flash
    litellm_params:
      model: gemini/gemini-3.1-flash-image-preview
      api_key: os.environ/GEMINI_API_KEY

  # Gemini 3 Pro Image (High quality, 4K)
  - model_name: img-gemini-3-pro
    litellm_params:
      model: gemini/gemini-3-pro-image-preview
      api_key: os.environ/GEMINI_API_KEY

  # xAI Grok Imagine Image (Standard)
  - model_name: img-grok-imagine
    litellm_params:
      model: xai/grok-imagine-image
      api_key: os.environ/XAI_API_KEY

  # xAI Grok Imagine Image Pro (Premium, faster)
  - model_name: img-grok-imagine-pro
    litellm_params:
      model: xai/grok-imagine-image-pro
      api_key: os.environ/XAI_API_KEY

# ============================================================
# LITELLM SETTINGS
# ============================================================

litellm_settings:
  drop_params: true
  # Auto-inject cache_control into system messages for Anthropic models
  # Reduces input token cost by ~90% for repeated system prompts
  # Safe for non-Anthropic models: drop_params=true strips unsupported params
  cache_control_injection_points:
    - location: "message"
      role: "system"
  host: "0.0.0.0"
  port: 4000
  telemetry: false
  request_timeout: 120
  num_retries: 2

general_settings:
  enable_spend_logging: false
  verbose: false
  master_key: os.environ/LITELLM_KEY
  log_level: "warning"
  max_parallel_requests: 50

logging:
  file: "litellm/litellm.log"
  level: INFO
